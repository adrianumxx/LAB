# Copia in .env.local (non committare). Per lavorare in locale PUOI lasciare tutto vuoto:
# l’app parte lo stesso; login/dashboard useranno Supabase solo quando compili le variabili.

# Dashboard Supabase → Settings → API
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Solo server — inviti email (Auth Admin). Mai NEXT_PUBLIC_.
# SUPABASE_SERVICE_ROLE_KEY=

# Opzionale: canonical URL (sitemap, metadata)
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Opzionale: email vendite per CTA Enterprise su /pricing (mailto). Senza: link di fallback.
# NEXT_PUBLIC_SALES_EMAIL=sales@example.com

# Solo se in dev vuoi il refresh session nel middleware (default: spento in next dev)
# SUPABASE_MIDDLEWARE_IN_DEV=1

# --- Stripe (Sprint 7–12) — Checkout multi-piano, Portal, webhook (docs/stripe-setup.md)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# Prezzi ricorrenti (mensili), uno per piano — vedi /pricing
# STRIPE_PRICE_ID_SOLO=price_...
# STRIPE_PRICE_ID_START=price_...
# STRIPE_PRICE_ID_CORE=price_...
# STRIPE_PRICE_ID_PRO=price_...
# Opzionale: fallback solo per PRO se STRIPE_PRICE_ID_PRO non è impostato (legacy Sprint 7)
# STRIPE_PRICE_ID=price_...
# Opzionale: blocca dashboard se non c’è abbonamento active/trialing
# STRIPE_ENFORCE_SUBSCRIPTION=0

# --- Resend (solo server, mai NEXT_PUBLIC_) — Sprint 9 / email transazionali (docs/resend-setup.md)
# RESEND_API_KEY=re_xxxx
# RESEND_FROM_EMAIL=onboarding@resend.dev
# CRON_SECRET=stringa-lunga-per-chiamare-scheduled-reminder-in-sicurezza
